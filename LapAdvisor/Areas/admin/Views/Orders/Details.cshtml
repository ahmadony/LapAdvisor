@model LapAdvisor.Model.VmAdminOrderDetails

<div class="card shadow-sm">
    <div class="card-header bg-gradient-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="fas fa-receipt me-2"></i>
            Order Details #@Model.InvoiceId
        </h4>

        <a asp-area="admin" asp-controller="Orders" asp-action="List" class="btn btn-light btn-sm">
            <i class="fas fa-arrow-left"></i> Back
        </a>
    </div>

    <div class="card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <div class="p-3 border rounded">
                    <div class="text-muted">Customer</div>
                    <div class="fw-bold">@Model.CustomerName</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-3 border rounded">
                    <div class="text-muted">Invoice Date</div>
                    <div class="fw-bold">@Model.InvoiceDate.ToString("dd MMM yyyy")</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-3 border rounded">
                    <div class="text-muted">Delivery Date</div>
                    <div class="fw-bold">@Model.DelivryDate.ToString("dd MMM yyyy")</div>
                </div>
            </div>
        </div>

        <form asp-area="admin" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="mb-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="invoiceId" value="@Model.InvoiceId" />

            <div class="d-flex gap-2 align-items-center">
                <label class="fw-bold mb-0">Order Status:</label>

                <select class="form-select w-auto" name="orderStatus">
                    <option selected="@(Model.OrderStatus == "Pending")">Pending</option>
                    <option selected="@(Model.OrderStatus == "Processing")">Processing</option>
                    <option selected="@(Model.OrderStatus == "Shipped")">Shipped</option>
                    <option selected="@(Model.OrderStatus == "Delivered")">Delivered</option>
                    <option selected="@(Model.OrderStatus == "Cancelled")">Cancelled</option>
                </select>

                <button class="btn btn-primary">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-center">Qty</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Line Total</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var it in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="~/Uploads/Items/@it.ImageName" style="width:50px;height:50px;object-fit:cover;border-radius:8px" />
                                    <div class="fw-bold">@it.ItemName</div>
                                </div>
                            </td>
                            <td class="text-center">@it.Qty</td>
                            <td class="text-end">JD @it.Price</td>
                            <td class="text-end fw-bold">JD @it.LineTotal</td>
                        </tr>
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Total:</td>
                        <td class="text-end fw-bold text-primary">JD @Model.Total</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
