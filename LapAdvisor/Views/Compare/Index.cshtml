@model List<LapAdvisor.Models.VwItem>

@{
    ViewData["Title"] = "Compare";
}

<div class="container my-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">Compare Laptops</h2>
            <small class="text-muted">Compare up to 4 laptops side-by-side.</small>
        </div>

        <div class="d-flex gap-2">
            <a href="/Recommendation" class="btn btn-outline-dark">Back to Recommendation</a>
            <button class="btn btn-solid" onclick="clearCompare()">Clear</button>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="card p-4 text-center">
            <h5 class="mb-2">No items in compare list</h5>
            <p class="text-muted mb-3">Go to Recommendation and add laptops to compare.</p>
            <a href="/Recommendation" class="btn btn-solid">Go to Recommendation</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle text-center">
                <thead>
                    <tr>
                        <th style="min-width:180px;">Feature</th>
                        @foreach (var it in Model)
                        {
                            <th style="min-width:240px;">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="text-start">
                                        <div class="fw-bold">@it.ItemName</div>
                                        <div class="text-muted small">JD @it.SalesPrice</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="removeCompare(@it.ItemId)">
                                        ✕
                                    </button>
                                </div>

                                <div class="mt-2">
                                    <a href="/Items/ItemDetails/@it.ItemId">
                                        <img src="/Uploads/Items/@(it.ImageName ?? "no-image.png")"
                                             style="max-height:130px;object-fit:contain;" class="img-fluid" />
                                    </a>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td class="text-start fw-bold">Brand</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.CategoryName</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">Type</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.ItemTypeName</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">CPU</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.Processor</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">GPU</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.Gpu</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">RAM</td>
                        @foreach (var it in Model)
                        {
                            <td>@(it.RamSize ?? 0) GB</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">Storage</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.HardDisk</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">Screen Size</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.ScreenSize</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">Resolution</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.ScreenReslution</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">OS</td>
                        @foreach (var it in Model)
                        {
                            <td>@it.OsName</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-start fw-bold">Action</td>
                        @foreach (var it in Model)
                        {
                            <td>
                                <a href="/Items/ItemDetails/@it.ItemId" class="btn btn-sm btn-solid">
                                    View Details
                                </a>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    }
</div>
