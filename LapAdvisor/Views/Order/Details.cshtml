@model LapAdvisor.Model.VmOrderDetails

<!-- breadcrumb start -->
<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>Order Details</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="breadcrumb-item">
                            <a asp-controller="Order" asp-action="MyOrders">My Orders</a>
                        </li>
                        <li class="breadcrumb-item active">Details</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- breadcrumb End -->

<section class="section-b-space">
    <div class="container">

        <div class="row mb-4">
            <div class="col-12">
                <div class="card p-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-center">
                        <div>
                            <h3 class="mb-1">Order #@Model.Invoice.InvoiceId</h3>
                            <p class="mb-0 text-muted">
                                Date: @Model.Invoice.InvoiceDate.ToString("yyyy-MM-dd HH:mm")
                            </p>
                        </div>

                        <div>
                            <span class="badge badge-pill px-3 py-2"
                                  style="font-size:14px; background:#f1f1f1; color:#333;">
                                Status: @Model.Invoice.OrderStatus
                            </span>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-4">
                            <p class="mb-1"><strong>Delivery Date:</strong></p>
                            <p class="text-muted mb-0">@Model.Invoice.DelivryDate.ToString("yyyy-MM-dd")</p>
                        </div>

                        <div class="col-md-4">
                            <p class="mb-1"><strong>Total Items:</strong></p>
                            <p class="text-muted mb-0">@Model.Items.Count</p>
                        </div>

                        <div class="col-md-4">
                            <p class="mb-1"><strong>Order Total:</strong></p>
                            <p class="mb-0" style="font-weight:700; font-size:18px;">
                                JD @Model.Total
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card p-3">
                    <h4 class="mb-3">Items</h4>

                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th style="width:90px;">Image</th>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Qty</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.ImageName))
                                            {
                                                <img src="~/Uploads/Items/@item.ImageName"
                                                     style="width:70px; height:70px; object-fit:cover; border-radius:10px;"
                                                     alt="">
                                            }
                                            else
                                            {
                                                <div style="width:70px; height:70px; background:#f3f3f3; border-radius:10px;"></div>
                                            }
                                        </td>
                                        <td>
                                            <div style="font-weight:600">@item.ItemName</div>
                                            <div class="text-muted" style="font-size:12px;">ID: @item.ItemId</div>
                                        </td>
                                        <td>JD @item.Price</td>
                                        <td>@item.Qty</td>
                                        <td style="font-weight:700;">JD @item.LineTotal</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <a asp-controller="Order" asp-action="MyOrders" class="btn btn-solid btn-sm">
                            Back to My Orders
                        </a>

                        <div style="font-size:18px; font-weight:800;">
                            Total: JD @Model.Total
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</section>
