@model ShoppingCart

<!-- breadcrumb start -->
<div class="breadcrumb-section">
    <div class="container">
        <div class="row">
            <div class="col-sm-6">
                <div class="page-title">
                    <h2>cart</h2>
                </div>
            </div>
            <div class="col-sm-6">
                <nav aria-label="breadcrumb" class="theme-breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
                        <li class="breadcrumb-item active">cart</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- breadcrumb End -->
<!--section start-->
<section class="cart-section section-b-space">
    <div class="container">
        <div class="row">
            <div class="col-sm-12">
                <table class="table cart-table table-responsive-xs">
                    <thead>
                        <tr class="table-head">
                            <th scope="col">image</th>
                            <th scope="col">product name</th>
                            <th scope="col">price</th>
                            <th scope="col">quantity</th>
                            <th scope="col">action</th>
                            <th scope="col">total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.lstItems)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Items" asp-action="ItemDetails" asp-route-id="@item.ItemId"><img src="~/Uploads/Items/@item.ImageName" alt=""></a>
                                </td>
                                <td>
                                    <a href="#">@item.ItemName</a>
                                    <div class="mobile-cart-content row">
                                        <div class="col-xs-3">
                                            <div class="qty-box">
                                                <div class="input-group">
                                                    <input type="text" name="quantity" class="form-control input-number qty"
                                                           value="1">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-xs-3">
                                            <h2 class="td-color">$63.00</h2>
                                        </div>
                                        <div class="col-xs-3">
                                            <h2 class="td-color">
                                                <a href="#" class="icon"><i class="ti-close"></i></a>
                                            </h2>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <h2>JD @item.Price</h2>
                                </td>
                                <td>
                                    <div class="qty-box">
                                        <div class="input-group">
                                            <input type="number"
                                                   class="form-control input-number qty"
                                                   data-id="@item.ItemId"
                                                   value="@item.Qty"
                                                   min="1"
                                                   onchange="ChangeQty(this)">

                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <a href="javascript:void(0)" class="icon" onclick="RemoveItem(@item.ItemId)">
                                        <i class="ti-close"></i>
                                    </a>
                                </td>

                                <td>
                                    <h2 id="rowTotal_@item.ItemId" class="td-color">@item.Total</h2>

                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
                <table class="table cart-table table-responsive-md">
                    <tfoot>
                        <tr>
                            <td>total price :</td>
                            <td>
                                <h2 id="OverAllTotal">JD @Model.Total</h2>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        <div class="row cart-buttons">
            <div class="col-6"><a href="/Home/Index" class="btn btn-solid">continue shopping</a></div>
            <div class="col-6">
                <a asp-controller="Order"
                   asp-action="Checkout"
                   class="btn btn-solid">
                    check out
                </a>
            </div>
        </div>
    </div>
</section>
<!--section end-->
@section Scripts
{
    <script src="~/Frontend/js/cart.js"></script>
}
