@model TbPages

<!-- HERO BANNER -->
<section class="about-hero position-relative">
    <img src="~/Uploads/Pages/@Model.ImageName" class="img-fluid w-100 rounded shadow-lg" style="max-height:500px; object-fit:cover;" />
</section>

<!-- CONTENT SECTION -->
<section class="section-b-space mt-5">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6 mb-4">
                <h2 class="fw-bold mb-3">@Model.Title</h2>
                <div class="lead text-muted" style="line-height:1.9;">
                    @Html.Raw(Model.Description)
                </div>
            </div>

            <div class="col-lg-6 text-center">
                <img src="~/Uploads/Pages/@Model.ImageName"
                     class="img-fluid rounded shadow-lg" alt="">
            </div>

        </div>
    </div>
</section>
