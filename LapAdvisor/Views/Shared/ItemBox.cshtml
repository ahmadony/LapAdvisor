@model VwItem

<div class="product-box">
    <div class="img-wrapper">
        <div class="front">
            <a asp-controller="Items" asp-action="ItemDetails" asp-route-id="@Model.ItemId">
                <img src="~/Uploads/Items/@Model.ImageName"
                     class="img-fluid blur-up lazyload bg-img" alt="">
            </a>
        </div>
            <a href="javascript:void(0)"
               class="btn-wishlist"
               data-itemid="@Model.ItemId"
               data-inwishlist="false">
                <i class="fa fa-heart"></i>
            </a> 

        <a asp-controller="Order" asp-action="AddToCart"
           asp-route-itemId="@Model.ItemId" class="add-button">
            add to cart
        </a>
    </div>

    <div class="product-detail">
        <div class="rating">
            <i class="fa fa-star"></i>
            <i class="fa fa-star"></i>
            <i class="fa fa-star"></i>
            <i class="fa fa-star"></i>
            <i class="fa fa-star"></i>
        </div>

        <a href="#">
            <h6>@Model.ItemName</h6>
        </a>

        <h4>JD @Model.SalesPrice</h4>
    </div>
</div>
